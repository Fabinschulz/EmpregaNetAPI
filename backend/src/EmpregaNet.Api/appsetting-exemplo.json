{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgreSQLConnection": "Host=localhost;Port=5432;Database=nome_do_banco;Username=nome_do_usuario;Password=senha_do_usuario;"
  },
  "JwtSettings": {
    "SecretKey": "TroqueEstaChavePorUmSegredoLongoDePeloMenos32Caracteres!",
    "ExpirationHours": 8,
    "Issuer": "EmpregaNet.Api",
    "Audience": "EmpregaNet.App",
    "RefreshTokenExpirationDays": 14
  },
  "AppUrls": {
    "PublicAppBaseUrl": "https://localhost:3000",
    "PasswordResetPath": "/reset-password",
    "EmailConfirmationPath": "/confirm-email",
    "CorsAllowedOrigins": ["http://localhost:3000", "https://localhost:3000"]
  },
  "GoogleAuth": {
    "ClientIds": []
  },
  "Smtp": {
    "Enabled": false,
    "Host": "",
    "Port": 587,
    "Security": "StartTls",
    "UserName": "",
    "Password": "",
    "FromEmail": "",
    "FromName": "EmpregaNet"
  },
  "Seed": {
    "AdminEmail": "",
    "AdminUserName": "",
    "AdminPassword": ""
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowInSeconds": 10,
    "QueueLimit": 0
  },
  "Sentry": {
    "Dsn": ""
  },
  "Redis": {
    "Enabled": false,
    "ConnectionString": "localhost:6379",
    "InstanceName": "EmpregaNet:"
  },
  "OutputCache": {
    "DefaultExpirationMinutes": 90,
    "SizeLimitMegabytes": 100,
    "MaximumBodySizeMegabytes": 100
  }
}
